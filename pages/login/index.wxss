.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #ffffff 50%);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.login-header {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #E53935 0%, #D32F2F 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 32rpx rgba(229, 57, 53, 0.3);
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #666666;
}

.user-type-section {
  margin-bottom: 24rpx;
}

.user-type-tabs {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.user-type-tab {
  flex: 1;
  max-width: 300rpx;
  background: #ffffff;
  border: 4rpx solid #E0E0E0;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
}

.user-type-tab.active {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-color: #4CAF50;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.2);
}

.tab-icon {
  font-size: 56rpx;
}

.tab-text {
  font-size: 30rpx;
  color: #666666;
  font-weight: 500;
}

.user-type-tab.active .tab-text {
  color: #2E7D32;
  font-weight: 600;
}

.login-form {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 0 40rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
}

.login-tabs {
  display: flex;
  border-bottom: 2rpx solid #EEEEEE;
  margin-bottom: 28rpx;
}

.tab-item {
  flex: 1;
  padding: 32rpx 0;
  text-align: center;
  position: relative;
  font-size: 30rpx;
  color: #666666;
}

.tab-item.active {
  color: #2E7D32;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2E7D32;
  border-radius: 2rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 96rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  color: #333333;
  background: transparent;
}

.verify-btn {
  padding: 16rpx 24rpx;
  background: #2E7D32;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #ffffff;
}

.verify-btn:active {
  opacity: 0.8;
}

.forgot-btn {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #999999;
}

.agree-section {
  margin-bottom: 32rpx;
}

.agree-checkbox {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #ffffff;
}

.checkbox.checked {
  background: #2E7D32;
  border-color: #2E7D32;
}

.agree-text {
  color: #666666;
}

.agree-link {
  color: #2E7D32;
}

.login-btn {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  border-radius: 16rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
}

.login-btn text {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.login-btn:active {
  transform: scale(0.98);
}

.quick-btn {
  background: #F5F5F5;
  border-radius: 16rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-btn text {
  font-size: 30rpx;
  color: #666666;
}

.login-footer {
  text-align: center;
  margin-bottom: 40rpx;
}

.footer-text {
  font-size: 28rpx;
  color: #999999;
}

.footer-link {
  font-size: 28rpx;
  color: #2E7D32;
  margin-left: 8rpx;
}

.feature-list {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  padding-bottom: 40rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.feature-icon {
  font-size: 48rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #666666;
}

.test-btn {
  background: #E3F2FD;
  border: 2rpx solid #2196F3;
  border-radius: 16rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32rpx;
}

.test-btn text {
  font-size: 30rpx;
  color: #1976D2;
  font-weight: 500;
}

.test-user-btn {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
  border-radius: 16rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 32rpx 32rpx 32rpx;
}

.test-user-btn text {
  font-size: 30rpx;
  color: #2E7D32;
  font-weight: 500;
}