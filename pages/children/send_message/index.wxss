.send-message-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 32rpx;
}

.header-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.elder-info {
  display: flex;
  align-items: center;
}

.elder-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: 600;
}

.message-input-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.message-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
  border: none;
  outline: none;
}

.char-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  font-size: 24rpx;
  color: #999999;
}

.quick-messages {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.quick-title {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-bottom: 16rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.quick-item {
  background: #E3F2FD;
  color: #1976D2;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  max-width: 100%;
}

.action-section {
  margin-bottom: 32rpx;
}

.send-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  border-radius: 44rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.send-btn:active {
  opacity: 0.8;
}

.history-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  padding: 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}

.history-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.history-content text:first-child {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
}

.history-time {
  font-size: 22rpx;
  color: #999999;
  margin-left: 16rpx;
  white-space: nowrap;
}