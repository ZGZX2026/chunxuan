.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #ffffff 30%);
  padding-bottom: 220rpx;
}

.profile-header {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  padding: 48rpx 32rpx;
  padding-top: calc(48rpx + env(safe-area-inset-top));
}

.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 64rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-btn {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #ffffff;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background: #ffffff;
  margin: -32rpx 32rpx 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
}

.stat-divider {
  width: 2rpx;
  background: #EEEEEE;
}

.menu-section {
  margin: 0 32rpx 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.menu-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.menu-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 12rpx;
}

.menu-text {
  font-size: 26rpx;
  color: #666666;
}

.menu-list {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.menu-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.menu-row:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-sm {
  font-size: 40rpx;
}

.menu-label {
  font-size: 32rpx;
  color: #333333;
}

.menu-right {
  font-size: 36rpx;
  color: #CCCCCC;
}

.menu-arrow {
  font-size: 40rpx;
}

.logout-btn {
  background: #F5F5F5;
  border-radius: 20rpx;
  padding: 28rpx;
  text-align: center;
}

.logout-btn text {
  font-size: 32rpx;
  color: #E53935;
  font-weight: 500;
}

.footer-info {
  padding: 24rpx 32rpx;
  margin: 32rpx;
  background: #ffffff;
  text-align: center;
  border-radius: 16rpx;
}

.footer-copyright {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.footer-disclaimer {
  font-size: 20rpx;
  color: #BBBBBB;
  display: block;
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 20rpx;
  color: #BBBBBB;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  position: relative;
}

.nav-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #999999;
}

.nav-item.active .nav-text {
  color: #4CAF50;
  font-weight: 600;
}

.nav-badge {
  position: absolute;
  top: 8rpx;
  right: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #E53935;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}