.relate-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  padding-bottom: 60rpx;
}

.relate-header {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  padding: 60rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.2);
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

.search-section {
  padding: 32rpx;
}

.search-input-group {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 32rpx;
  color: #333333;
  height: 48rpx;
}

.search-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  padding: 20rpx 40rpx;
  border-radius: 32rpx;
}

.search-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.search-results {
  padding: 0 32rpx 32rpx;
}

.results-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.results-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.result-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.result-item:last-child {
  border-bottom: none;
}

.result-avatar {
  width: 96rpx;
  height: 96rpx;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.result-avatar text {
  font-size: 56rpx;
}

.result-info {
  flex: 1;
}

.result-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.result-phone {
  font-size: 28rpx;
  color: #999999;
}

.result-action {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  padding: 20rpx 40rpx;
  border-radius: 32rpx;
}

.action-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.linked-section {
  margin: 0 32rpx 32rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.linked-list {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.linked-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.linked-item:last-child {
  border-bottom: none;
}

.elder-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.elder-avatar {
  width: 96rpx;
  height: 96rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.elder-icon {
  font-size: 56rpx;
}

.elder-detail {
  display: flex;
  flex-direction: column;
}

.elder-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.elder-phone {
  font-size: 28rpx;
  color: #999999;
}

.elder-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  width: 80rpx;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn text {
  font-size: 40rpx;
}

.action-btn.danger {
  background: #FFEBEE;
}

.action-btn.danger text {
  color: #E53935;
}

.empty-state {
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #999999;
}

.tips-section {
  margin: 0 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tips-icon {
  font-size: 48rpx;
}

.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.tips-number {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  flex-shrink: 0;
}

.tips-text {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.6;
  flex: 1;
}

.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  max-width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx;
  text-align: center;
  border-bottom: 2rpx solid #F5F5F5;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.modal-body {
  padding: 40rpx;
}

.elder-info-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.card-avatar {
  width: 120rpx;
  height: 120rpx;
  background: #E8F5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-avatar text {
  font-size: 72rpx;
}

.card-info {
  flex: 1;
}

.card-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.card-phone {
  font-size: 30rpx;
  color: #999999;
}

.modal-tip {
  font-size: 32rpx;
  color: #666666;
  text-align: center;
  display: block;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #F5F5F5;
}

.modal-btn {
  flex: 1;
  padding: 32rpx;
  text-align: center;
}

.modal-btn text {
  font-size: 34rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  border-right: 2rpx solid #F5F5F5;
}

.modal-btn.cancel text {
  color: #999999;
}

.modal-btn.confirm text {
  color: #4CAF50;
}