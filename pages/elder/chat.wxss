.chat-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

.chat-header {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  padding: 32rpx;
  padding-top: calc(32rpx + env(safe-area-inset-top));
  text-align: center;
  position: relative;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: calc(32rpx + env(safe-area-inset-top));
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
}

.back-btn text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 500;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-prompt {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.prompt-content {
  text-align: center;
}

.prompt-icon {
  font-size: 140rpx;
  margin-bottom: 40rpx;
}

.prompt-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 20rpx;
}

.prompt-desc {
  font-size: 34rpx;
  color: #666666;
  display: block;
  margin-bottom: 48rpx;
}

.prompt-btn {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  padding: 28rpx 96rpx;
  border-radius: 48rpx;
  display: inline-block;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
}

.prompt-btn text {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.chat-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.welcome-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 48rpx;
}

.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: center;
}

.tag {
  padding: 24rpx 40rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  font-size: 34rpx;
  color: #333333;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.tag:active {
  background: #E8F5E9;
  color: #2E7D32;
}

.chat-messages {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.bottom-anchor {
  height: 1rpx;
  width: 100%;
}

.message-block {
  margin-bottom: 24rpx;
}

.user-message {
  display: flex;
  justify-content: flex-end;
}

.user-message .message-content {
  max-width: 75%;
}

.user-bubble {
  background: #2E7D32;
  padding: 28rpx 36rpx;
  border-radius: 32rpx 32rpx 8rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 125, 50, 0.2);
}

.user-bubble .message-text {
  font-size: 36rpx;
  line-height: 1.7;
  color: #ffffff;
}

.bot-message {
  display: flex;
  justify-content: flex-start;
}

.bot-message .message-content {
  max-width: 85%;
}

.bot-bubble {
  background: #FFFFFF;
  padding: 28rpx 36rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.bot-bubble .message-text {
  font-size: 36rpx;
  line-height: 1.8;
  color: #333333;
  white-space: pre-wrap;
}

.message-actions {
  display: flex;
  gap: 32rpx;
  margin-top: 20rpx;
  padding-left: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: #F0F0F0;
  border-radius: 32rpx;
}

.action-btn:active {
  background: #E8F5E9;
}

.action-icon {
  font-size: 36rpx;
}

.action-text {
  font-size: 30rpx;
  color: #666666;
  font-weight: 500;
}

.footer-info {
  padding: 24rpx 32rpx;
  margin: 32rpx;
  background: #ffffff;
  text-align: center;
  border-radius: 16rpx;
}

.footer-copyright {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.footer-disclaimer {
  font-size: 20rpx;
  color: #BBBBBB;
  display: block;
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 20rpx;
  color: #BBBBBB;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.voice-section {
  margin-bottom: 20rpx;
}

.voice-btn {
  width: 100%;
  height: 120rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
}

.voice-btn:active {
  transform: scale(0.98);
}

.voice-icon {
  font-size: 56rpx;
}

.voice-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.input-section {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.chat-input {
  flex: 1;
  height: 96rpx;
  padding: 0 32rpx;
  background: #F0F0F0;
  border-radius: 48rpx;
  font-size: 34rpx;
}

.send-btn {
  background: #2E7D32;
  color: #ffffff;
  padding: 28rpx 56rpx;
  border-radius: 48rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.send-btn:active {
  opacity: 0.9;
}