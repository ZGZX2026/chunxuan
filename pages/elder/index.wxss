.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 160rpx;
}

.login-prompt {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.prompt-content {
  text-align: center;
  margin-bottom: 80rpx;
}

.prompt-icon {
  font-size: 160rpx;
  margin-bottom: 48rpx;
}

.prompt-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 24rpx;
}

.prompt-desc {
  font-size: 36rpx;
  color: #666666;
  display: block;
  margin-bottom: 56rpx;
}

.prompt-btn {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  padding: 32rpx 112rpx;
  border-radius: 56rpx;
  display: inline-block;
  box-shadow: 0 12rpx 32rpx rgba(46, 125, 50, 0.3);
}

.prompt-btn text {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.prompt-features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 32rpx;
}

.prompt-feature {
  width: 180rpx;
  text-align: center;
  padding: 32rpx 16rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.feature-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.feature-name {
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

.welcome-section {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  padding: 48rpx;
  padding-top: calc(48rpx + env(safe-area-inset-top));
  text-align: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  overflow: hidden;
}

.avatar-inner {
  width: 100rpx;
  height: 120rpx;
  position: relative;
}

.avatar-head {
  width: 60rpx;
  height: 60rpx;
  background: #ffffff;
  border-radius: 50%;
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}

.avatar-body {
  width: 80rpx;
  height: 60rpx;
  background: #ffffff;
  border-radius: 40rpx 40rpx 20rpx 20rpx;
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
}

.greeting {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.time-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 24rpx;
}

.logout-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
}

.logout-btn text {
  font-size: 32rpx;
  color: #ffffff;
}

.health-card {
  margin: 32rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.health-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.health-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}

.health-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.health-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #999999;
}

.health-dot.active {
  background: #4CAF50;
}

.health-text {
  font-size: 30rpx;
  color: #666666;
}

.health-data-large {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.health-item-large {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 20rpx;
}

.health-icon-large {
  font-size: 72rpx;
}

.health-info-large {
  flex: 1;
}

.health-value-large {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  display: block;
}

.health-label-large {
  font-size: 32rpx;
  color: #666666;
}

.status-card-large {
  margin: 32rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.status-header-large {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.status-title-large {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
}

.status-indicator-large {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #F0F0F0;
}

.status-indicator-large.active {
  background: #E8F5E9;
}

.status-indicator-large.inactive {
  background: #FFF3E0;
}

.indicator-dot-large {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #999999;
}

.status-indicator-large.active .indicator-dot-large {
  background: #4CAF50;
}

.status-indicator-large.inactive .indicator-dot-large {
  background: #FF9800;
}

.indicator-text-large {
  font-size: 32rpx;
  color: #666666;
  font-weight: 500;
}

.status-info-large {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.info-item-large {
  text-align: center;
}

.info-value-large {
  font-size: 48rpx;
  font-weight: 700;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
}

.info-label-large {
  font-size: 30rpx;
  color: #666666;
}

.status-btn-large {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  border-radius: 20rpx;
  text-align: center;
}

.status-btn-large text {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 每日提醒样式 - 更大更突出 */
.medicine-reminder-large {
  margin: 32rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
  border-radius: 40rpx;
  padding: 48rpx;
  border-left: 16rpx solid #2196F3;
  box-shadow: 0 16rpx 40rpx rgba(33, 150, 243, 0.25);
}

.reminder-content-large {
  display: flex;
  align-items: flex-start;
  gap: 32rpx;
}

.reminder-icon-wrapper-large {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 24rpx;
}

.reminder-icon-large {
  font-size: 100rpx;
}

.speak-icon {
  font-size: 56rpx;
}

.reminder-info-large {
  flex: 1;
}

.reminder-title-large {
  font-size: 52rpx;
  font-weight: 700;
  color: #1976D2;
  display: block;
  margin-bottom: 20rpx;
}

.reminder-text-large {
  font-size: 44rpx;
  color: #1565C0;
  line-height: 1.8;
}

.reminder-btn-large {
  padding: 32rpx 48rpx;
  background: #2196F3;
  border-radius: 28rpx;
  align-self: center;
}

.reminder-btn-large text {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.ai-reminder {
  margin: 32rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFECB3 100%);
  border-radius: 40rpx;
  padding: 48rpx;
  border-left: 16rpx solid #FF9800;
  box-shadow: 0 16rpx 40rpx rgba(255, 152, 0, 0.25);
}

.ai-reminder-content {
  display: flex;
  align-items: flex-start;
  gap: 32rpx;
}

.ai-reminder-icon-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 24rpx;
}

.ai-reminder-icon {
  font-size: 100rpx;
}

.ai-reminder-info {
  flex: 1;
}

.ai-reminder-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #E65100;
  display: block;
  margin-bottom: 20rpx;
}

.ai-reminder-text {
  font-size: 44rpx;
  color: #5D4037;
  line-height: 1.8;
}

.ai-reminder-btn {
  padding: 32rpx 48rpx;
  background: #FF9800;
  border-radius: 28rpx;
  align-self: center;
}

.ai-reminder-btn text {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
}

.emergency-section-large {
  margin: 32rpx;
  text-align: center;
}

.emergency-btn-large {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #E53935 0%, #C62828 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(229, 57, 53, 0.4);
}

.emergency-icon-large {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.emergency-text-large {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.emergency-tip-large {
  font-size: 30rpx;
  color: #999999;
}

.quick-actions-large {
  margin: 32rpx;
}

.action-list-large {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-item-full {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.action-icon-large {
  font-size: 80rpx;
}

.action-text-large {
  font-size: 44rpx;
  font-weight: 600;
  color: #333333;
  flex: 1;
}

.footer-info {
  padding: 24rpx 32rpx;
  margin: 32rpx;
  background: #ffffff;
  text-align: center;
  border-radius: 16rpx;
}

.footer-copyright {
  font-size: 22rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.footer-disclaimer {
  font-size: 20rpx;
  color: #BBBBBB;
  display: block;
  margin-bottom: 8rpx;
}

.footer-icp {
  font-size: 20rpx;
  color: #BBBBBB;
}

.elder-bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
  padding-bottom: env(safe-area-inset-bottom);
}

.elder-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.elder-nav-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.elder-nav-text {
  font-size: 28rpx;
  color: #666666;
}

.elder-nav-item.active .elder-nav-icon {
  transform: scale(1.1);
}

.elder-nav-item.active .elder-nav-text {
  color: #2E7D32;
  font-weight: 600;
}